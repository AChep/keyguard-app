import kotlin.time.Instant;

CREATE TABLE barcodeUsageHistory (
  id TEXT NOT NULL PRIMARY KEY,
  type TEXT NOT NULL,
  createdAt INTEGER AS Instant NOT NULL
);

getById:
SELECT *
FROM barcodeUsageHistory
WHERE id = :id;

getRecent:
SELECT *
FROM barcodeUsageHistory
ORDER BY createdAt DESC
LIMIT :limit;

upsert:
INSERT OR REPLACE INTO barcodeUsageHistory(id, type, createdAt)
VALUES (:id, :type, :createdAt);

deleteAll:
DELETE FROM barcodeUsageHistory;
