<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="WearCredentialProviderTestTheme.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="windowSplashScreenBackground">@color/launcher_background</item>
        <item name="postSplashScreenTheme">@style/WearCredentialProviderTestTheme</item>
    </style>

    <style name="WearCredentialProviderTestTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/launcher_background</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
