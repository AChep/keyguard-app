---
import { SITE, REPO_URL } from '../consts';
import HeroDevicesV2 from './HeroDevicesV2.astro';
---

<section class="relative isolate overflow-hidden bg-surface">
  <div class="mx-auto max-w-3xl px-6 pt-24 text-center sm:pt-28">
    <h1 class="text-balance text-4xl font-extrabold tracking-tight text-on-surface sm:text-6xl">
      {SITE.tagline}
    </h1>
  </div>

  <HeroDevicesV2 />

  <div class="mx-auto max-w-3xl px-6 pb-16 text-center">
    <p class="mx-auto mt-6 max-w-2xl text-lg text-on-surface-variant">
      {SITE.description}
    </p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/download/"
        class="rounded-full bg-primary px-7 py-3 text-base font-semibold text-on-primary shadow-sm transition hover:opacity-90"
      >
        Download
      </a>
      <a
        href={REPO_URL}
        class="glass glass-hover inline-flex items-center gap-2 rounded-full px-7 py-3 text-base font-semibold text-on-surface"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.75.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.25 5.68.42.36.79 1.07.79 2.16v3.2c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z" />
        </svg>
        Explore source code
      </a>
    </div>
  </div>
</section>
