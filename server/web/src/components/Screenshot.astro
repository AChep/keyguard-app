---
import { Image } from 'astro:assets';

// A feature screenshot. Pass an imported image as `src` to render it (with
// rounded corners + a subtle shadow); omit `src` to show a labelled placeholder
// describing what the screenshot should eventually show.
//   <Screenshot src={shot} caption="What it shows" />
interface Props {
  src?: ImageMetadata;
  alt?: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---

<figure class="my-8">
  {
    src ? (
      // Cap the width on a plain wrapper, not the <Image>: Astro injects an
      // unlayered `max-width:100%` on [data-astro-image] that would beat a
      // (layered) Tailwind max-w-* utility on the image itself.
      <div class="mx-auto max-w-[312px]">
        <Image
          src={src}
          alt={alt ?? caption ?? ''}
          width={312}
          class="block h-auto w-full rounded-xl shadow-lg ring-1 ring-black/5 dark:ring-white/10"
        />
      </div>
    ) : (
      <div
        class="flex aspect-video w-full flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-outline-variant bg-surface-container text-on-surface-variant"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="9" cy="9" r="2"></circle>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
        </svg>
        <span class="text-xs font-medium uppercase tracking-wide">Screenshot placeholder</span>
      </div>
    )
  }
  {
    caption && (
      <figcaption class="mt-2 text-center text-sm text-on-surface-variant">
        {caption}
      </figcaption>
    )
  }
</figure>
