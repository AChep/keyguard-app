---
import { Image } from 'astro:assets';
// iPhone frame (Dynamic Island). Pass `src` for a screenshot.
interface Props {
  src?: ImageMetadata;
  alt?: string;
  sizes?: string;
  widths?: number[];
}
const {
  src,
  alt = '',
  sizes = '(min-width: 640px) 180px, 134px',
  widths = [180, 360, 540],
} = Astro.props;
---

<div class="w-full select-none">
  <div class="device-shadow relative aspect-[9/19.5] rounded-[2.4rem] border border-white/10 bg-[#0e0e10] p-[3.5%]">
    <div class="relative h-full w-full overflow-hidden rounded-[1.9rem] bg-surface-container">
      {/* Dynamic Island */}
      <span class="absolute left-1/2 top-[2.2%] z-10 h-[2.8%] w-[24%] -translate-x-1/2 rounded-full bg-black ring-1 ring-white/10"></span>
      {
        src ? (
          <Image src={src} alt={alt} widths={widths} sizes={sizes} class="absolute inset-0 h-full w-full object-cover" />
        ) : (
          <div class="flex h-full w-full flex-col items-center justify-center gap-2 text-on-surface-variant">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <circle cx="9" cy="9" r="2" />
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
            </svg>
            <span class="text-[0.65rem] font-medium uppercase tracking-wide">iPhone</span>
          </div>
        )
      }
    </div>
  </div>
</div>
