---
import { Image } from 'astro:assets';
// Laptop frame (lid + keyboard deck). The `variant` only changes small details:
// mac gets a display notch and a silver deck, windows/linux get a webcam dot.
interface Props {
  src?: ImageMetadata;
  alt?: string;
  variant?: 'mac' | 'windows' | 'linux';
  sizes?: string;
  widths?: number[];
}
const {
  src,
  alt = '',
  variant = 'mac',
  sizes = '(min-width: 640px) 660px, 250px',
  // Capped at 960 so the same widths stay within every source image used here
  // (the smallest, linux.png, is 1167px wide) — Astro never upscales.
  widths = [320, 640, 960],
} = Astro.props;
const isMac = variant === 'mac';
const label = { mac: 'macOS', windows: 'Windows', linux: 'Linux' }[variant];
---

<div class="w-full select-none">
  {/* Lid */}
  <div class="relative z-10 mx-auto w-[86%]">
    <div class="relative aspect-[16/10] rounded-t-[0.8rem] border border-b-0 border-white/10 bg-[#0e0e10] p-[2.4%] pb-[1.4%]">
      <div class="relative h-full w-full overflow-hidden rounded-t-[0.35rem] bg-surface-container">
        {
          isMac ? (
            <span class="absolute left-1/2 top-0 z-10 h-[4.5%] w-[15%] -translate-x-1/2 rounded-b-[0.3rem] bg-[#0e0e10]"></span>
          ) : (
            <span class="absolute left-1/2 top-[1.8%] z-10 h-1 w-1 -translate-x-1/2 rounded-full bg-black/70 ring-1 ring-white/10"></span>
          )
        }
        {
          src ? (
            // The desktop screenshot is a floating window on a transparent
            // background, so it sits contained over a wallpaper gradient.
            <div class="absolute inset-0 bg-gradient-to-br from-[#262b35] via-[#181b21] to-[#0d0e12]">
              <Image src={src} alt={alt} widths={widths} sizes={sizes} fit="contain" class="absolute inset-0 h-full w-full object-contain p-[4%] -translate-y-1/28" />
            </div>
          ) : (
            <div class="flex h-full w-full flex-col items-center justify-center gap-2 text-on-surface-variant">
              <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="9" cy="9" r="2" />
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
              </svg>
              <span class="text-[0.65rem] font-medium uppercase tracking-wide">{label}</span>
            </div>
          )
        }
      </div>
    </div>
  </div>

  {/* Base / keyboard deck */}
  <div
    class:list={[
      'device-shadow relative h-3 w-full rounded-b-[0.7rem] rounded-t-[0.2rem] border border-t-0',
      isMac
        ? 'border-white/20 bg-gradient-to-b from-[#d7d7db] to-[#9fa0a6]'
        : 'border-white/10 bg-gradient-to-b from-[#2c2c31] to-[#121214]',
    ]}
  >
    {/* thumb scoop */}
    <span
      class:list={[
        'absolute left-1/2 top-0 h-1.5 w-[14%] -translate-x-1/2 rounded-b-[0.5rem]',
        isMac ? 'bg-[#8a8b91]' : 'bg-black/50',
      ]}
    ></span>
  </div>
</div>
