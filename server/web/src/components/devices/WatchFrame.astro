---
import { Image } from 'astro:assets';
// Pixel Watch frame (round, domed case with side crown and band hints).
interface Props {
  src?: ImageMetadata;
  alt?: string;
  sizes?: string;
  widths?: number[];
}
const {
  src,
  alt = '',
  sizes = '(min-width: 640px) 104px, 88px',
  widths = [104, 208, 312],
} = Astro.props;
---

<div class="relative aspect-square w-full select-none">
  {/* Bands behind the case */}
  <div class="absolute left-1/2 top-[-26%] h-[34%] w-[44%] -translate-x-1/2 rounded-t-xl bg-gradient-to-b from-[#222226] to-[#161618]"></div>
  <div class="absolute bottom-[-26%] left-1/2 h-[34%] w-[44%] -translate-x-1/2 rounded-b-xl bg-gradient-to-t from-[#222226] to-[#161618]"></div>

  {/* Crown */}
  <div class="absolute right-[-2.5%] top-1/2 h-[15%] w-[7%] -translate-y-1/2 rounded-full bg-gradient-to-r from-[#303036] to-[#1c1c20]"></div>

  {/* Domed case */}
  <div class="device-shadow absolute inset-0 rounded-full border border-white/10 bg-[#0e0e10] p-[9%]">
    <div class="relative h-full w-full overflow-hidden rounded-full bg-surface-container">
      {
        src ? (
          <Image src={src} alt={alt} widths={widths} sizes={sizes} class="absolute inset-0 h-full w-full object-cover" />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-on-surface-variant">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <circle cx="9" cy="9" r="2" />
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
            </svg>
          </div>
        )
      }
    </div>
  </div>
</div>
