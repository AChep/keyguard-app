---
import BaseLayout from './BaseLayout.astro';
import DocLink from '../components/DocLink.astro';
import { getDocGroups } from '../lib/docs';

interface Props {
  title: string;
  description?: string;
  /** id of the currently rendered doc, e.g. "getting-started"; undefined on the docs index */
  currentId?: string;
}

const { title, description, currentId } = Astro.props;

const groups = await getDocGroups();
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto flex max-w-6xl flex-col gap-10 px-6 py-12 md:flex-row">
    <aside class="md:w-60 md:shrink-0">
      <details id="docs-nav" class="group" open>
        {/* On mobile this summary is a tap-to-expand bar; hidden from md up where
            the sidebar is always shown (the inline script keeps it open there). */}
        <summary class="flex cursor-pointer list-none items-center justify-between rounded-xl border border-outline-variant px-4 py-3 font-medium text-on-surface md:hidden [&::-webkit-details-marker]:hidden">
          Documentation
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-on-surface-variant transition-transform group-open:rotate-180">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </summary>
        <nav class="mt-4 flex flex-col gap-6 text-sm md:mt-0">
          {
            groups.map((group) => (
              <div>
                <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-on-surface-variant">
                  {group.label}
                </p>
                <div class="flex flex-col gap-1">
                  {group.entries.map((entry) =>
                    entry.kind === 'doc' ? (
                      <DocLink doc={entry.doc} currentId={currentId} />
                    ) : (
                      <div class="mt-1 flex flex-col gap-1 border-l border-outline-variant pl-3 ml-3">
                        <p class="px-3 pt-1 text-xs font-semibold text-on-surface-variant">
                          {entry.subsection.label}
                        </p>
                        {entry.subsection.docs.map((doc) => (
                          <DocLink doc={doc} currentId={currentId} />
                        ))}
                      </div>
                    ),
                  )}
                </div>
              </div>
            ))
          }
        </nav>
      </details>
    </aside>

    <article class="prose-doc min-w-0 flex-1">
      <h1 class="mb-6 text-3xl font-extrabold tracking-tight text-on-surface">
        {title}
      </h1>
      <slot />
    </article>
  </div>

  <script is:inline>
    // Collapse the docs nav on small screens; keep it open (and the toggle bar
    // hidden) from md up. Defaults to open in the HTML, so it still works without JS.
    (function () {
      const nav = document.getElementById('docs-nav');
      if (!nav) return;
      const mq = window.matchMedia('(min-width: 768px)');
      const sync = () => { nav.open = mq.matches; };
      sync();
      mq.addEventListener('change', sync);
    })();
  </script>
</BaseLayout>
