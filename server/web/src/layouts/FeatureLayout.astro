---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { FEATURE_VISUALS, DEFAULT_VISUAL } from '../featureVisuals';

interface Props {
  title: string;
  summary: string;
  slug?: string;
  premium?: boolean;
}

const { title, summary, slug, premium = false } = Astro.props;
const v = (slug && FEATURE_VISUALS[slug]) || DEFAULT_VISUAL;
---

<BaseLayout title={title} description={summary}>
  <article class="mx-auto max-w-3xl px-6 py-12">
    <nav class="mb-8 text-sm text-on-surface-variant">
      <a href="/features/" class="transition hover:text-primary">Features</a>
      <span class="px-2">/</span>
      <span class="text-on-surface">{title}</span>
    </nav>

    <header class="mb-10">
      <div class:list={['mb-4 flex h-14 w-14 items-center justify-center rounded-2xl', v.chip, v.ink]}>
        <Icon name={v.icon} class="h-7 w-7" />
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-on-surface">
        {title}
      </h1>
      {
        premium && (
          <span class="mt-3 inline-block rounded-full bg-primary-container px-3 py-1 text-xs font-semibold text-on-primary-container">
            Premium feature
          </span>
        )
      }
      <p class="mt-4 text-lg text-on-surface-variant">{summary}</p>
    </header>

    <div class="prose-doc">
      <slot />
    </div>

    <footer class="mt-14 flex flex-wrap items-center justify-between gap-4 border-t border-outline-variant pt-8">
      <a href="/features/" class="text-sm font-medium text-primary transition hover:opacity-80">
        ← All features
      </a>
    </footer>
  </article>
</BaseLayout>
